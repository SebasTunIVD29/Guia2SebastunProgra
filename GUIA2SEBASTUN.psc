Algoritmo Ejercicio3
	Definir letra Como Caracter
	Escribir Sin Saltar "Dijite na letra: "
	Leer letra
	
	Segun letra Hacer
		"A" o "a":
			Escribir "EXELENTE"
		"B" o "b":
			Escribir "BUENO"
		"C" o "c":
			Escribir "REGULAR"
		"D" o "d":
			Escribir "DEFICIENTE"
		"F" o "f":
			Escribir "REPROBADO"
		De Otro Modo:
			Escribir "Letra no Valida!!!"
	Fin Segun
	
FinAlgoritmo
